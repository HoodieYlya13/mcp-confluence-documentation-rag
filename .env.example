# Document source: "local" (bundled mock files, air-gapped) or "confluence" (live API)
DOCUMENT_SOURCE=confluence

# Atlassian Cloud credentials — create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_URL=https://your-site.atlassian.net
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=your-api-token

# Space holding the operational documentation (seeded by scripts/seed_confluence.py)
CONFLUENCE_SPACE_KEY=ATSOPS

# Retrieval backend: "semantic" (LlamaIndex + Chroma + local embeddings) or "tfidf" (NumPy, zero-dep)
RETRIEVER_BACKEND=semantic

# LLM backend: "auto" (gemini if key present, else stub), "gemini", "ollama", "stub"
LLM_BACKEND=auto
GEMINI_API_KEY=your-gemini-key

# MCP transport: "stdio" (local desktop client) or "streamable-http" (remote)
MCP_TRANSPORT=stdio

# Identity — stdio: role of the local process owner; HTTP: token->role registry (JSON)
STDIO_ROLE=JUNIOR_OP
AUTH_TOKENS={"DEMO_JUNIOR": "JUNIOR_OP", "DEMO_LEAD": "ATS_CORE_LEAD"}

# Single sign-on (optional) — also accept OIDC access tokens from the identity
# provider, in addition to AUTH_TOKENS. Leave SSO_ISSUER empty to disable.
# SSO_ISSUER / SSO_AUDIENCE / SSO_JWKS_URL each accept ONE value or a bracketed
# list "[a, b]" (positional: jwks_url[i] pairs with issuer[i]). SSO_AUDIENCE is
# the OIDC client_id; a token matches if any `aud` OR its `azp` is in the list.
SSO_ISSUER=[https://auth.hy13dev.com, https://miam-keycloak-miam-1.durnal.groupe.pharmagest.com/realms/pros]
SSO_AUDIENCE=[confluence-spotlight-gjOtqPBt, admin-durnal-dev]
# Keycloak does NOT serve keys at /.well-known/jwks.json — its JWKS endpoint is
# {issuer}/protocol/openid-connect/certs. Supply it positionally when reachable:
# SSO_JWKS_URL=[https://auth.hy13dev.com/.well-known/jwks.json, https://miam-keycloak-miam-1.durnal.groupe.pharmagest.com/realms/pros/protocol/openid-connect/certs]

# DEMO-ONLY signature bypass. Any issuer listed here skips JWKS/signature
# verification (issuer-allowlist + aud/azp + exp are STILL enforced). This exists
# solely because the hosted demo cannot reach the corporate Keycloak through the
# company VPN/firewall; the demo serves only mocked CERN data and exposes no
# protected files. Leave EMPTY in production — auth.hy13dev.com is fully verified.
# See SECURITY.md.
SSO_INSECURE_ISSUER=[https://miam-keycloak-miam-1.durnal.groupe.pharmagest.com/realms/pros]

# Hugging Face deployment (scripts/deploy_hf_space.py) — requires a WRITE token
HF_TOKEN=your-hf-token

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
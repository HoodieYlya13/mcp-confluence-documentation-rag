# Document source: "local" (bundled mock files, air-gapped) or "confluence" (live API)
DOCUMENT_SOURCE=confluence

# Atlassian Cloud credentials — create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_URL=https://your-site.atlassian.net
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=your-api-token

# Space holding the operational documentation (seeded by scripts/seed_confluence.py)
CONFLUENCE_SPACE_KEY=ATSOPS

# Retrieval backend: "semantic" (LlamaIndex + Chroma + local embeddings) or "tfidf" (NumPy, zero-dep)
RETRIEVER_BACKEND=semantic

# LLM backend: "auto" (gemini if key present, else stub), "gemini", "ollama", "stub"
LLM_BACKEND=auto
GEMINI_API_KEY=your-gemini-key

# MCP transport: "stdio" (local desktop client) or "streamable-http" (remote)
MCP_TRANSPORT=stdio

# Identity — stdio: role of the local process owner; HTTP: token->role registry (JSON)
STDIO_ROLE=JUNIOR_OP
AUTH_TOKENS={"replace-with-strong-random-token": "JUNIOR_OP", "another-strong-token": "ATS_CORE_LEAD"}

# Hugging Face deployment (scripts/deploy_hf_space.py) — requires a WRITE token
HF_TOKEN=your-hf-token
